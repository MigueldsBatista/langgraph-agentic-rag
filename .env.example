# Hugging Face Settings
# Create a Hugging Face account and token (optional for some models, but required for gated ones)
HF_TOKEN=your_huggingface_token_here
HF_HUB_DISABLE_PROGRESS_BARS=1
TQDM_DISABLE=1

# LLM Configs
# Target local llama.cpp server configuration
MODEL_NAME=unsloth/gemma-4-E4B-it-GGUF
MODEL_BASE_URL=http://localhost:8080
MODEL_API_KEY=your_api_key_here

# Embedding / Vector Store Settings
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DOC_SPLITS_PATH=models/doc_splits.pkl
